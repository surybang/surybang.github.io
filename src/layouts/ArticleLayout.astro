---
import '../styles/global.css';

const { frontmatter } = Astro.props;
const { title, date, tags = [] } = frontmatter;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title} · fabien-hos</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="toolbar">
  <div class="toolbar-row">
    <div class="fname">
      <span class="dot">~/logs/</span>{title}<span class="ipy">.md</span>
    </div>
    <div class="kernel">
      <span class="kdot"></span>Markdown
    </div>
  </div>
</div>

<div class="article-wrap">
  <a href="/logs" class="back-link">← logs.ipynb</a>
  <h1>{title}</h1>
  <div class="article-meta">
    {date && <span>{date}</span>}
    {tags.map((t: string) => <span>#{t}</span>)}
  </div>
  <slot />
</div>

<footer>
  <span>© 2026 Fabien HOS</span>
  <span>kernel: python3 · hébergé sur GitHub Pages</span>
</footer>

</body>
</html>
